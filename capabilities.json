{
  "dataRoles": [
    {
      "name": "Category",
      "kind": "Grouping",
      "displayName": "Category",
      "description": "The category field to analyze (e.g. defect type, product, region)."
    },
    {
      "name": "Measure",
      "kind": "Measure",
      "displayName": "Measure",
      "description": "The numeric measure to aggregate and rank (e.g. count, cost, revenue)."
    },
    {
      "name": "Tooltips",
      "kind": "Measure",
      "displayName": "Tooltips",
      "description": "Additional measures to display in the tooltip."
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "Category": {
            "max": 1
          },
          "Measure": {
            "min": 1,
            "max": 20
          },
          "Tooltips": {
            "max": 20
          }
        }
      ],
      "categorical": {
        "categories": {
          "for": {
            "in": "Category"
          },
          "dataReductionAlgorithm": {
            "top": {
              "count": 30000
            }
          }
        },
        "values": {
          "select": [
            {
              "bind": {
                "to": "Measure"
              }
            },
            {
              "bind": {
                "to": "Tooltips"
              }
            }
          ],
          "dataReductionAlgorithm": {
            "top": {
              "count": 30000
            }
          }
        }
      }
    }
  ],
  "drilldown": {
    "roles": [
      "Category"
    ],
    "maxLevels": 5
  },
